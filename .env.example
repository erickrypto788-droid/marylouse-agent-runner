# =========================================
# Telegram Affiliate Agent - Variáveis
# =========================================

# Segurança: enquanto DRY_RUN=true o agente NÃO posta no Telegram.
DRY_RUN=true

# Telegram
# Crie com @BotFather e coloque o bot como admin do canal.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@seu_canal_ou_chat_id

# IA - OpenAI ou endpoint compatível com Chat Completions.
# Se ficar vazio, o agente usa um gerador de copy simples sem IA.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Amazon Product Advertising API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=seutag-20
AMAZON_HOST=webservices.amazon.com.br
AMAZON_REGION=us-east-1
AMAZON_MARKETPLACE=www.amazon.com.br

# Shopee Affiliate Open API
SHOPEE_APP_ID=
SHOPEE_SECRET=
SHOPEE_ENDPOINT=https://open-api.affiliate.shopee.com.br/graphql

# AliExpress Affiliate API
ALIEXPRESS_APP_KEY=
ALIEXPRESS_SECRET=
ALIEXPRESS_TRACKING_ID=
ALIEXPRESS_ENDPOINT=https://api-sg.aliexpress.com/sync

# Mercado Livre
ML_SITE_ID=MLB
# Opcional: se a API pública retornar 403/forbidden no seu ambiente, use um token do app ML.
ML_ACCESS_TOKEN=

# Banco local de controle anti-duplicidade
SQLITE_PATH=data/agent.sqlite3

# Limites
POST_LIMIT_PER_RUN=3
MAX_CANDIDATES_PER_RUN=80
RECENT_DUPLICATE_DAYS=10
